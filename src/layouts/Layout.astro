---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sure Stride',
  description = 'Optimize teamwork with Agile coaching. Elevate collaboration, efficiency, and innovation.',
} = Astro.props;

const pageTitle = title === 'Sure Stride' ? title : `${title} · Sure Stride`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Agile, Scrum, Kanban, Mentor, Coach, Engineering Manager" />
    <meta name="author" content="Dean Didion" />
    <link rel="icon" type="image/png" href="/img/favicon-32x32.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-white text-slate-800 antialiased font-sans">
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
