---
const socials = [
  {
    href: 'https://www.linkedin.com/in/dean-didion-b20a94ba/',
    label: 'LinkedIn',
    svg: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>',
  },
  {
    href: 'https://github.com/MightContainNuts',
    label: 'GitHub',
    svg: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  },
  {
    href: 'https://twitter.com/mightcontainuts',
    label: 'Twitter / X',
    svg: '<path d="M4 4l16 16M4 20L20 4"/>',
  },
  {
    href: 'https://www.freelancer.de/u/surestride68',
    label: 'Freelancer.de',
    svg: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>',
  },
];
---
<footer class="bg-slate-900 border-t border-slate-800 text-slate-400">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <div>
        <p class="text-teal-400 font-bold text-lg mb-2">Sure Stride</p>
        <p class="text-sm leading-relaxed">
          Agile coaching, engineering leadership, and mentorship for teams and individuals ready to level up.
        </p>
      </div>
      <div>
        <p class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Navigation</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-teal-400 transition-colors">Home</a></li>
          <li><a href="/services" class="hover:text-teal-400 transition-colors">Services</a></li>
          <li><a href="/about" class="hover:text-teal-400 transition-colors">About</a></li>
          <li><a href="/contact" class="hover:text-teal-400 transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Connect</p>
        <div class="flex gap-3 mb-4">
          {socials.map(({ href, label, svg }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="w-9 h-9 rounded-lg border border-slate-700 hover:border-teal-500 hover:text-teal-400 flex items-center justify-center transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" set:html={svg} />
            </a>
          ))}
        </div>
        <p class="text-sm">
          <a href="mailto:dean@surestride.net" class="hover:text-teal-400 transition-colors">
            dean@surestride.net
          </a>
        </p>
        <p class="text-sm mt-1">Geiseltalsee, Sachsen-Anhalt, Germany</p>
      </div>
    </div>
    <div class="mt-10 pt-8 border-t border-slate-800 text-center text-sm text-slate-500">
      <p>© {new Date().getFullYear()} Sure Stride · Dean Didion</p>
    </div>
  </div>
</footer>
