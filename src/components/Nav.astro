---
const links = [
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
];
---
<header class="fixed top-0 inset-x-0 z-50 bg-slate-900/95 backdrop-blur-sm border-b border-slate-800">
  <div class="max-w-6xl mx-auto px-6">
    <nav class="flex items-center justify-between h-16" aria-label="Main navigation">
      <a href="/" class="text-teal-400 font-bold text-xl tracking-tight hover:text-teal-300 transition-colors">
        Sure Stride
      </a>
      <div class="hidden md:flex items-center gap-8">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class="text-slate-300 hover:text-white transition-colors text-sm font-medium"
          >
            {label}
          </a>
        ))}
        <a
          href="/contact"
          class="text-sm font-semibold bg-teal-500 hover:bg-teal-400 text-white px-5 py-2 rounded-lg transition-colors"
        >
          Contact
        </a>
      </div>
      <button
        id="nav-toggle"
        class="md:hidden text-slate-300 hover:text-white p-2 rounded-lg"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>
  </div>
  <div id="mobile-menu" class="hidden md:hidden bg-slate-900 border-t border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      {links.map(({ href, label }) => (
        <a href={href} class="text-slate-300 hover:text-white text-sm font-medium py-2">
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="text-sm font-semibold bg-teal-500 hover:bg-teal-400 text-white px-5 py-2.5 rounded-lg transition-colors text-center mt-1"
      >
        Contact
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !isHidden);
    iconOpen?.classList.toggle('hidden', isHidden);
    iconClose?.classList.toggle('hidden', !isHidden);
    toggle.setAttribute('aria-expanded', String(isHidden));
  });
</script>
