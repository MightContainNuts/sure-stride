---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Get in touch with Dean Didion at Sure Stride for agile coaching, engineering management, and mentorship enquiries.">

  <!-- Page header -->
  <section class="relative bg-slate-900 pt-32 pb-20 overflow-hidden">
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: repeating-linear-gradient(-45deg, white, white 1px, transparent 1px, transparent 28px);"
      aria-hidden="true"
    ></div>
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-teal-500 via-teal-400 to-teal-600" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-6">
      <p class="text-teal-400 text-sm font-semibold tracking-widest uppercase mb-4">Get in Touch</p>
      <h1 class="text-white text-5xl md:text-6xl font-extrabold mb-6">Contact</h1>
      <p class="text-slate-300 text-xl max-w-xl leading-relaxed">
        Have a project in mind or want to explore working together? Drop me a message.
      </p>
    </div>
  </section>

  <!-- Contact form + info -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

        <!-- Form -->
        <div class="lg:col-span-3">
          <!--
            Formspree setup:
            1. Create a free account at formspree.io
            2. Create a new form and copy the form ID (e.g. xyzabcde)
            3. Replace YOUR_FORM_ID below with your actual ID
          -->
          <form
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="space-y-6"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 outline-none transition-colors text-slate-800 placeholder-slate-400"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 outline-none transition-colors text-slate-800 placeholder-slate-400"
                />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="What's it about?"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 outline-none transition-colors text-slate-800 placeholder-slate-400"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Tell me what you're working on…"
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 outline-none transition-colors text-slate-800 placeholder-slate-400 resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full sm:w-auto bg-teal-500 hover:bg-teal-400 text-white font-semibold px-10 py-3.5 rounded-lg transition-colors shadow-lg shadow-teal-500/20"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <p class="text-slate-900 text-sm font-semibold uppercase tracking-widest mb-5">Direct Contact</p>
            <div class="space-y-4">
              <a
                href="mailto:dean@surestride.net"
                class="flex items-center gap-3 text-slate-600 hover:text-teal-500 transition-colors group"
              >
                <div class="w-10 h-10 rounded-lg bg-slate-50 group-hover:bg-teal-50 border border-slate-100 flex items-center justify-center flex-shrink-0 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <span>dean@surestride.net</span>
              </a>
              <div class="flex items-center gap-3 text-slate-600">
                <div class="w-10 h-10 rounded-lg bg-slate-50 border border-slate-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <span>Geiseltalsee, Sachsen-Anhalt, Germany</span>
              </div>
            </div>
          </div>

          <div>
            <p class="text-slate-900 text-sm font-semibold uppercase tracking-widest mb-5">Find Me Online</p>
            <div class="space-y-3">
              <a href="https://www.linkedin.com/in/dean-didion-b20a94ba/" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 text-slate-600 hover:text-teal-500 transition-colors text-sm">
                <span class="text-teal-500 font-medium w-24">LinkedIn</span>
                <span>Dean Didion</span>
              </a>
              <a href="https://github.com/MightContainNuts" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 text-slate-600 hover:text-teal-500 transition-colors text-sm">
                <span class="text-teal-500 font-medium w-24">GitHub</span>
                <span>MightContainNuts</span>
              </a>
              <a href="https://www.freelancer.de/u/surestride68" target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-3 text-slate-600 hover:text-teal-500 transition-colors text-sm">
                <span class="text-teal-500 font-medium w-24">Freelancer.de</span>
                <span>surestride68</span>
              </a>
            </div>
          </div>

          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
            <p class="text-slate-900 font-semibold mb-2">Response time</p>
            <p class="text-slate-600 text-sm leading-relaxed">
              I typically respond within one business day. For urgent enquiries, email directly.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
